# Metadatabase

AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://svc_airflow:airflow@postgres:5432/airflow

# Celery

AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://svc_airflow:airflow@postgres:5432/airflow

AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0

# Web UI

_AIRFLOW_WWW_USER_USERNAME=airflow

_AIRFLOW_WWW_USER_PASSWORD=airflow

# Security

AIRFLOW__CORE__FERNET_KEY=tcExlub-6pIPmw_nlR7_9RwZqAsHVLtGriC-f1BML1c=
AIRFLOW__CORE__LOAD_EXAMPLES=false
#AIRFLOW__CORE__INTERNAL_API_URL=http://airflow-webserver:8080

# DAG Bundles 
AIRFLOW__DAG_PROCESSOR__DAG_BUNDLE_CONFIG_LIST=[{"name":"my-git-bundle","classpath":"airflow.providers.git.bundles.git.GitDagBundle","kwargs":{"tracking_ref":"main","git_conn_id":"my_git_conn"}},{"name":"dags-folder","classpath":"airflow.dag_processing.bundles.local.LocalDagBundle","kwargs":{}}]

